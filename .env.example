# Copy this file to .env and fill in your values (recommended over editing secrets.py directly for secrets)
# Then you can load with python-dotenv in a future refactor, or manually source them.

# LinkedIn (optional - the bot can also use saved browser profile)
LINKEDIN_USERNAME=your.email@example.com
LINKEDIN_PASSWORD=your_password_here

# AI Provider (set to grok for best "great job" agent experience)
AI_PROVIDER=grok
LLM_API_URL=https://api.x.ai/v1/
LLM_API_KEY=xai-your-xai-api-key-here
LLM_MODEL=grok-3          # or grok-4 / grok-beta — check https://x.ai/api for current available models
LLM_SPEC=openai

# Optional local / other
# LLM_API_URL=http://localhost:11434/v1/   # for Ollama etc.

# Whether to use AI features at all
USE_AI=True
